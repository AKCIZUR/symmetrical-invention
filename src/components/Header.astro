---
import { navSections, quickLinks, site } from '@/data/site';
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-zinc-950/70 backdrop-blur-2xl" transition:persist>
  <div class="mx-auto flex w-full max-w-7xl items-center gap-4 px-4 py-4 sm:px-6 lg:px-8">
    <a href="/" class="group flex items-center gap-3">
      <span class="flex h-10 w-10 items-center justify-center rounded-2xl border border-white/10 bg-white/5 text-sm font-semibold text-white shadow-lg shadow-black/20">N</span>
      <div class="leading-tight">
        <div class="text-sm font-medium tracking-[0.22em] text-zinc-300 uppercase">{site.name}</div>
        <div class="text-xs text-zinc-500">shadcn dark · liquid glass</div>
      </div>
    </a>

    <nav class="hidden flex-1 items-center justify-center gap-2 lg:flex">
      <div class="relative group">
        <button class="glass-btn">Dokumentace</button>
        <div class="glass-panel invisible absolute left-0 top-full mt-3 w-[820px] translate-y-2 p-4 opacity-0 shadow-2xl transition duration-200 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100">
          <div class="grid gap-3 md:grid-cols-2 xl:grid-cols-4">
            {navSections.map((section) => (
              <div class="space-y-3">
                <div class="text-xs font-semibold tracking-[0.18em] text-zinc-400 uppercase">{section.label}</div>
                <div class="space-y-2">
                  {section.items.map((item) => (
                    <a href={item.href} class="menu-item">
                      <div class="text-sm font-medium text-zinc-100">{item.title}</div>
                      <div class="text-xs leading-5 text-zinc-400">{item.description}</div>
                    </a>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
      <a href="/docs/" class="glass-btn">Docs</a>
      <a href="/blog/" class="glass-btn">Blog</a>
      <a href="/docs/customization/tema-a-promenne/" class="glass-btn">Design</a>
    </nav>

    <div class="ml-auto flex items-center gap-2">
      <button type="button" data-search-open class="glass-btn hidden items-center gap-2 sm:inline-flex" aria-label="Otevřít vyhledávání">
        <span class="text-sm">Vyhledat</span>
        <kbd class="kbd">⌘K</kbd>
      </button>
      <a href={quickLinks[1].href} class="glass-btn hidden sm:inline-flex">Blog</a>
      <a href="https://github.com/" class="glass-btn hidden md:inline-flex">GitHub</a>
    </div>
  </div>
</header>