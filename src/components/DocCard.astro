---
type Props = {
  title: string;
  description: string;
  href: string;
  meta?: string;
};
const { title, description, href, meta } = Astro.props;
---

<a href={href} class="glass-card group block p-5">
  {meta ? <div class="mb-3 text-xs tracking-[0.2em] text-zinc-500 uppercase">{meta}</div> : null}
  <h3 class="text-lg font-semibold text-white">{title}</h3>
  <p class="mt-2 text-sm leading-6 text-zinc-400">{description}</p>
  <div class="mt-4 text-sm font-medium text-white/70 group-hover:text-white">Otevřít →</div>
</a>