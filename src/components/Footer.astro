---
import { site } from '@/data/site';
---

<footer class="border-t border-white/10 bg-zinc-950/60 backdrop-blur-2xl">
  <div class="mx-auto flex w-full max-w-7xl flex-col gap-4 px-4 py-8 text-sm text-zinc-400 sm:px-6 lg:px-8 md:flex-row md:items-center md:justify-between">
    <p>© {new Date().getFullYear()} {site.name}. Minimalistická dokumentace v černobílém stylu.</p>
    <div class="flex flex-wrap gap-4">
      <a href="/docs/" class="hover:text-white">Docs</a>
      <a href="/blog/" class="hover:text-white">Blog</a>
      <a href="/docs/deployment/github-pages/" class="hover:text-white">GitHub Pages</a>
    </div>
  </div>
</footer>