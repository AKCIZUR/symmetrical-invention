---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="404" description="Stránka nenalezena.">
  <div class="mx-auto max-w-2xl py-24 text-center">
    <div class="glass-panel p-10">
      <div class="text-xs tracking-[0.25em] text-zinc-500 uppercase">404</div>
      <h1 class="mt-4 text-4xl font-semibold text-white">Stránka nenalezena</h1>
      <p class="mt-4 text-zinc-400">Odkaz neexistuje, nebo byl přesunut.</p>
      <div class="mt-8"><a href="/" class="glass-btn">Zpět na úvod</a></div>
    </div>
  </div>
</BaseLayout>