---
import BaseLayout from '@/layouts/BaseLayout.astro';
import DocCard from '@/components/DocCard.astro';
import { getCollection } from 'astro:content';

const docs = (await getCollection('docs')).sort((a, b) => a.data.order - b.data.order).slice(0, 6);
const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);
---

<BaseLayout title="NoirDocs" description="Shadcn-inspired dokumentační web v dark B&W stylu s liquid glass vzhledem a animovanými přechody.">
  <section class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr]">
    <div class="glass-panel p-8 sm:p-10">
      <div class="inline-flex rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs tracking-[0.25em] text-zinc-300 uppercase">
        GitHub Pages ready
      </div>
      <h1 class="mt-6 max-w-3xl text-5xl font-semibold tracking-tight text-white sm:text-6xl">
        Minimalistická dokumentace v černobílém liquid glass stylu.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-zinc-300">
        Vytvořeno pro Markdown dokumenty, megamenu, vyhledávání, stránkové přechody a čistý shadcn feeling bez zbytečného balastu.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/docs/" class="glass-btn">Otevřít dokumentaci</a>
        <a href="/blog/" class="glass-btn">Přečíst blog</a>
        <button type="button" data-search-open class="glass-btn">Vyhledat ⌘K</button>
      </div>
      <div class="mt-8 grid gap-3 sm:grid-cols-3">
        <div class="glass-card p-4">
          <div class="text-2xl font-semibold text-white">Markdown</div>
          <div class="mt-1 text-sm text-zinc-400">Obsah z content collections</div>
        </div>
        <div class="glass-card p-4">
          <div class="text-2xl font-semibold text-white">Liquid</div>
          <div class="mt-1 text-sm text-zinc-400">Sklo, blur a jemné vrstvy</div>
        </div>
        <div class="glass-card p-4">
          <div class="text-2xl font-semibold text-white">Static</div>
          <div class="mt-1 text-sm text-zinc-400">GitHub Pages deploy</div>
        </div>
      </div>
    </div>

    <div class="glass-panel p-8">
      <h2 class="text-xs tracking-[0.25em] text-zinc-400 uppercase">Rychlý přehled</h2>
      <div class="mt-5 space-y-3">
        <div class="glass-card p-4"><div class="text-sm text-zinc-400">Design</div><div class="mt-1 font-medium text-white">shadcn B&W + liquid glass</div></div>
        <div class="glass-card p-4"><div class="text-sm text-zinc-400">Navigace</div><div class="mt-1 font-medium text-white">megamenu, breadcrumbs, TOC</div></div>
        <div class="glass-card p-4"><div class="text-sm text-zinc-400">UX</div><div class="mt-1 font-medium text-white">přechody stránek a palette</div></div>
        <div class="glass-card p-4"><div class="text-sm text-zinc-400">Deploy</div><div class="mt-1 font-medium text-white">GitHub Actions + Pages</div></div>
      </div>
    </div>
  </section>

  <section class="mt-16 space-y-6">
    <div class="flex items-end justify-between gap-4">
      <div>
        <h2 class="text-2xl font-semibold text-white">Nejnovější dokumenty</h2>
        <p class="mt-2 text-zinc-400">Základní kostra, která se dá dál rozšiřovat.</p>
      </div>
      <a href="/docs/" class="text-sm text-zinc-300 hover:text-white">Všechny dokumenty →</a>
    </div>
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {docs.map((doc) => (
        <DocCard title={doc.data.title} description={doc.data.description} href={`/docs/${doc.slug}/`} meta={doc.data.section} />
      ))}
    </div>
  </section>

  <section class="mt-16 space-y-6">
    <div class="flex items-end justify-between gap-4">
      <div>
        <h2 class="text-2xl font-semibold text-white">Blog</h2>
        <p class="mt-2 text-zinc-400">Krátké články o designu, architektuře a nasazení.</p>
      </div>
      <a href="/blog/" class="text-sm text-zinc-300 hover:text-white">Všechny články →</a>
    </div>
    <div class="grid gap-4 md:grid-cols-3">
      {posts.map((post) => (
        <a href={`/blog/${post.slug}/`} class="glass-card block p-5">
          <div class="text-xs tracking-[0.22em] text-zinc-500 uppercase">{post.data.tags[0] ?? 'blog'}</div>
          <h3 class="mt-3 text-lg font-semibold text-white">{post.data.title}</h3>
          <p class="mt-2 text-sm leading-6 text-zinc-400">{post.data.description}</p>
          <div class="mt-4 text-sm text-zinc-300">{post.data.pubDate.toLocaleDateString('cs-CZ')}</div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>