---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog" description="Články o designu, vývoji a produkčním nasazení.">
  <div class="space-y-8">
    <div class="glass-panel p-8">
      <h1 class="text-4xl font-semibold text-white">Blog</h1>
      <p class="mt-4 max-w-3xl text-lg leading-8 text-zinc-300">
        Krátké technické poznámky, design směry a provozní tipy.
      </p>
    </div>

    <div class="grid gap-4 lg:grid-cols-2">
      {posts.map((post) => (
        <a href={`/blog/${post.slug}/`} class="glass-card block p-6">
          <div class="flex items-center justify-between gap-4">
            <div class="text-xs tracking-[0.25em] text-zinc-500 uppercase">{post.data.tags[0] ?? 'blog'}</div>
            <div class="text-xs text-zinc-500">{post.data.pubDate.toLocaleDateString('cs-CZ')}</div>
          </div>
          <h2 class="mt-4 text-2xl font-semibold text-white">{post.data.title}</h2>
          <p class="mt-3 text-sm leading-7 text-zinc-400">{post.data.description}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>