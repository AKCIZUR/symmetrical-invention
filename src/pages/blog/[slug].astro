---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const sorted = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return sorted.map((entry, index) => ({
    params: { slug: entry.slug },
    props: {
      entry,
      prev: index < sorted.length - 1 ? sorted[index + 1] : null,
      next: index > 0 ? sorted[index - 1] : null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content, headings } = await entry.render();
const toc = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <div class="grid gap-8 xl:grid-cols-[minmax(0,1fr)_18rem]">
    <article class="space-y-8">
      <div class="glass-panel p-8">
        <div class="text-xs tracking-[0.25em] text-zinc-500 uppercase">{entry.data.tags.join(' · ')}</div>
        <h1 class="mt-4 text-4xl font-semibold text-white">{entry.data.title}</h1>
        <p class="mt-4 max-w-3xl text-lg leading-8 text-zinc-300">{entry.data.description}</p>
        <div class="mt-6 text-sm text-zinc-500">{entry.data.pubDate.toLocaleDateString('cs-CZ')} · {entry.data.author}</div>
      </div>

      <div class="glass-panel prose prose-invert max-w-none p-8 prose-headings:scroll-mt-28 prose-a:text-white prose-strong:text-white">
        <Content />
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {prev ? (
          <a href={`/blog/${prev.slug}/`} class="glass-card p-5">
            <div class="text-xs tracking-[0.2em] text-zinc-500 uppercase">Starší článek</div>
            <div class="mt-2 text-lg font-semibold text-white">{prev.data.title}</div>
          </a>
        ) : <div />}
        {next ? (
          <a href={`/blog/${next.slug}/`} class="glass-card p-5 text-right">
            <div class="text-xs tracking-[0.2em] text-zinc-500 uppercase">Novější článek</div>
            <div class="mt-2 text-lg font-semibold text-white">{next.data.title}</div>
          </a>
        ) : <div />}
      </div>
    </article>

    <aside class="glass-panel sticky top-28 hidden h-fit w-72 p-4 xl:block">
      <div class="mb-3 text-xs font-semibold tracking-[0.22em] text-zinc-400 uppercase">On this page</div>
      {toc.length ? (
        <nav class="space-y-1">
          {toc.map((heading) => (
            <a href={`#${heading.slug}`} class:list={['toc-link', { 'pl-5': heading.depth === 3 }]}>
              {heading.text}
            </a>
          ))}
        </nav>
      ) : <p class="text-sm text-zinc-500">Žádný obsah k zobrazení.</p>}
    </aside>
  </div>
</BaseLayout>